# =============================================================================
# Votometria — variáveis de ambiente (copie para .env e preencha)
# O .env e *.env estão no .gitignore; nunca faça commit de segredos.
# =============================================================================

# --- Google Sheets: arquitetura medalhão (bronze / prata / ouro) -------------
# Uma planilha por camada. O ID é o trecho da URL entre /d/ e /edit.
#   extractors  -> bronze   (dados brutos)
#   transformers-> prata    (dados limpos/normalizados)
#   loaders     -> ouro     (dados finais; consumidos pelo frontend e pela API)
SHEET_ID_bronze=
SHEET_ID_prata=
SHEET_ID_ouro=

# Service account JSON compartilhado pelas três planilhas (Editor em todas).
# Caminho relativo é resolvido a partir da raiz do projeto. Mantenha em secrets/.
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service_account.json

# (Legado) planilha única — mantido apenas para compatibilidade com get_spreadsheet().
# GOOGLE_SHEETS_ID=

# --- Backend API -------------------------------------------------------------
# Origens permitidas do frontend, separadas por vírgula.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# (Opcional) Só é necessário se algum código legado ainda usar PostgreSQL.
# O pipeline e a API de market-expectations agora usam a camada ouro (sheets).
# DATABASE_URL=
