# Database connection URL (PostgreSQL)
DATABASE_URL=

# Google Sheets sync
# ID of the destination spreadsheet (the long token in the sheet URL).
GOOGLE_SHEETS_ID=
# Path to the service account JSON key file. Relative paths are resolved from
# the project root. Keep this file out of version control (e.g. under secrets/).
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/service_account.json

# Allowed frontend origins for the backend API, separated by commas
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://votometria.vercel.app
