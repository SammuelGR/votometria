# Google Sheets ID used by the public gviz CSV endpoint.
# Must be the GOLD (ouro) spreadsheet — same value as SHEET_ID_ouro in the
# backend/scripts .env. The frontend reads the consolidated gold tabs from it.
VITE_GOOGLE_SHEETS_ID=

VITE_API_BASE_URL=http://localhost:8000/api
# Production: https://votometria.onrender.com/api
